<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AirVault - Tested AirPods</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      background: #f5f5f5;
      margin: 0;
      padding: 0;
      color: #333;
    }
    header {
      background: black;
      color: white;
      padding: 20px 0;
      text-align: center;
    }
    header h1 {
      margin: 0;
      font-size: 2rem;
    }
    header p {
      margin: 5px 0 0 0;
      font-size: 1rem;
      color: #ddd;
    }
    .products {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      margin: 20px;
    }
    .product {
      background: white;
      width: 300px;
      margin: 15px;
      border-radius: 10px;
      box-shadow: 0 4px 6px rgba(0,0,0,0.1);
      padding: 20px;
      text-align: center;
    }
    .product img {
      width: 150px;
      margin-bottom: 10px;
    }
    .product h2 {
      margin: 10px 0;
      font-size: 1.2rem;
    }
    .product p {
      font-size: 1rem;
      margin: 5px 0 15px 0;
    }
    .product button {
      background: black;
      color: white;
      border: none;
      padding: 10px 20px;
      border-radius: 5px;
      cursor: pointer;
      font-size: 1rem;
    }
    footer {
      text-align: center;
      padding: 20px 0;
      background: #222;
      color: #ccc;
      margin-top: 30px;
    }
    a {
      color: #1e90ff;
      text-decoration: none;
    }
  </style>
</head>
<body>

  <header>
    <h1>AirVault</h1>
    <p>Tested & Cleaned AirPods | DM to Buy</p>
  </header>

  <div class="products">
    <div class="product">
      <img src="https://via.placeholder.com/150" alt="AirPods Gen 2">
      <h2>AirPods Gen 2</h2>
      <p>$65 – Cleaned & Tested</p>
      <button onclick="window.location.href='https://instagram.com/airvault'">DM to Buy</button>
    </div>
    <div class="product">
      <img src="https://via.placeholder.com/150" alt="AirPods Pro">
      <h2>AirPods Pro</h2>
      <p>$95 – Refurbished & Tested</p>
      <button onclick="window.location.href='https://instagram.com/airvault'">DM to Buy</button>
    </div>
  </div>

  <footer>
    <p>Follow us on <a href="https://instagram.com/airvault" target="_blank">Instagram @AirVault</a></p>
  </footer>

</body>
</html>
